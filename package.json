{
  "name": "flacr",
  "productName": "flacr.",
  "version": "0.6.1",
  "description": "flacr",
  "author": {
    "name": "xceekaay",
    "email": "xceekaay@proton.me"
  },
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite --port 5173\" \"cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.flacr.app",
    "productName": "flacr.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "src/assets/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png",
      "category": "Audio"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "xceekaay",
      "repo": "flacr"
    }
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  }
}
